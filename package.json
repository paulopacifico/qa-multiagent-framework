{
  "name": "qa-multiagent-framework",
  "version": "1.0.0",
  "description": "Multi-agent quality gate system that validates every phase of a software project — spec, plan, code, and CI — before work advances.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "pretest:e2e": "node -e \"const fs = require('fs'); for (const dir of ['allure-results', 'test-results', 'playwright-report']) fs.rmSync(dir, { recursive: true, force: true });\"",
    "test:e2e": "playwright test",
    "gates": "ts-node -P tsconfig.test.json scripts/run-gates.ts",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run test:e2e && npm run gates"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "keywords": [
    "qa",
    "testing",
    "multi-agent",
    "quality-gates",
    "playwright",
    "typescript",
    "automation"
  ],
  "author": "Paulo Pacifico",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulopacifico/qa-multiagent-framework.git"
  },
  "bugs": {
    "url": "https://github.com/paulopacifico/qa-multiagent-framework/issues"
  },
  "homepage": "https://github.com/paulopacifico/qa-multiagent-framework#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "allure-playwright": "^3.7.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
